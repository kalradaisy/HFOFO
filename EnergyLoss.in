physics QGSP_BIC doStochastics=0 

beam gaussian particle=mu+ meanMomentum=172 nEvents=100
trackcuts keep=mu+

param histoFile=EnergyLoss

material C A=12.011 Z=6 density=1.69

tubs Target outerRadius=100 material=C length=2.5 color=1,0,0

virtualdetector DetBefore radius=500 color=0,0,1
virtualdetector DetAfter radius=500 color=0,1,0

place DetBefore z=95
place Target z=100
place DetAfter z=200
